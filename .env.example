# Database — PostgreSQL on AWS RDS Mumbai
DATABASE_URL=postgresql://ytip_app:password@rds-host:5432/ytip
# Read-only connection (optional, falls back to DATABASE_URL)
DATABASE_URL_READONLY=postgresql://ytip_app:password@rds-host:5432/ytip

# Claude AI
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Email notifications (Resend)
RESEND_API_KEY=re_xxxxx
NOTIFY_EMAILS=owner@yourstruly.in,manager@yourstruly.in

# PetPooja POS Integration
PETPOOJA_APP_KEY=pending
PETPOOJA_APP_SECRET=pending
PETPOOJA_ACCESS_TOKEN=pending
PETPOOJA_RESTAURANT_ID=pending
PETPOOJA_BASE_URL=https://api.petpooja.com/v2

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend CORS
CORS_ORIGINS=http://localhost:3000

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
