# Database — PostgreSQL on AWS RDS Mumbai
DATABASE_URL=postgresql://ytip_app:password@rds-host:5432/ytip
# Read-only connection (optional, falls back to DATABASE_URL)
DATABASE_URL_READONLY=postgresql://ytip_app:password@rds-host:5432/ytip

# Claude AI
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Email notifications (Resend)
RESEND_API_KEY=re_xxxxx
NOTIFY_EMAILS=owner@yourstruly.in,manager@yourstruly.in

# PetPooja POS — Orders API
PETPOOJA_APP_KEY=
PETPOOJA_APP_SECRET=
PETPOOJA_ACCESS_TOKEN=
PETPOOJA_RESTAURANT_ID=
PETPOOJA_REST_ID=
PETPOOJA_COOKIE=
PETPOOJA_BASE_URL=https://api.petpooja.com/v2

# PetPooja — Menu API (separate credentials)
PETPOOJA_MENU_APP_KEY=
PETPOOJA_MENU_APP_SECRET=
PETPOOJA_MENU_ACCESS_TOKEN=

# PetPooja — Inventory API (Stock, COGS, Purchases — separate credentials)
PETPOOJA_INV_APP_KEY=
PETPOOJA_INV_APP_SECRET=
PETPOOJA_INV_ACCESS_TOKEN=

# PetPooja — CO Cookie (for Stock/Purchase/Sales APIs)
PETPOOJA_CO_COOKIE=

# WhatsApp Cloud API (Meta Developer Console)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=ytip-verify-2026
WHATSAPP_BUSINESS_ACCOUNT_ID=

# OpenAI (for Whisper voice transcription)
OPENAI_API_KEY=sk-xxxxx

# Owner WhatsApp (for proactive briefings — country code, no +)
OWNER_WHATSAPP=919876543210

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend CORS
CORS_ORIGINS=http://localhost:3000

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
