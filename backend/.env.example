# ============================================================================
# YoursTruly Intelligence Platform — Environment Variables
# Copy to backend/.env and fill in the blanks marked with YOUR_*
# ============================================================================

# Database (RDS PostgreSQL Mumbai)
DATABASE_URL=YOUR_RDS_CONNECTION_STRING
# e.g. postgresql://ytip:password@ytip-instance.xxxxx.ap-south-1.rds.amazonaws.com:5432/ytip
DATABASE_URL_READONLY=

# Claude AI
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY

# ── PetPooja Orders API (generic — no consumed[] data) ──
PETPOOJA_APP_KEY=uvw0th4nksi97o1bgqp35zjxr6e2may8
PETPOOJA_APP_SECRET=9450cbbbb22be056537e82138f1fa15220656e9b
PETPOOJA_ACCESS_TOKEN=9949a4aea79acad2e22e501e89c5ff3146f15e48
PETPOOJA_RESTAURANT_ID=34cn0ieb1f
PETPOOJA_REST_ID=34cn0ieb1f

# ── PetPooja Menu API (NOTE: uses HYPHENS in HTTP headers, not underscores) ──
PETPOOJA_MENU_APP_KEY=necpbimxzuogtyhr5qf19k63adsw0vj8
PETPOOJA_MENU_APP_SECRET=cfba0cad2a51d753740984feb9d1caea6d09c1cc
PETPOOJA_MENU_ACCESS_TOKEN=d0ab024f7351a490d517e52942afac2c759dea07

# ── PetPooja Inventory API (THE GOLDMINE — has consumed[] for COGS) ──
PETPOOJA_INV_APP_KEY=rpvg7joamn421d3u0x5qhk9ze8sibtcw
PETPOOJA_INV_APP_SECRET=c7b1e4b80a2d1bfbf67da2bc81ca9dd9bf019b3e
PETPOOJA_INV_ACCESS_TOKEN=7334c01be3a9677868cbf1402880340e79e1ea84

# ── PetPooja Cookies (needed for Stock/Purchase/Sales APIs) ──
# Get these from browser DevTools → Application → Cookies on inventory.petpooja.com
PETPOOJA_COOKIE=
PETPOOJA_CO_COOKIE=

# ── WhatsApp Cloud API (optional for v1) ──
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=ytip-verify-2026
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ── Telegram (optional) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── OpenAI (for Whisper STT — optional, defer to v2) ──
OPENAI_API_KEY=

# ── Email notifications (optional) ──
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@yourstruly.in
NOTIFY_EMAILS=

# ── Owner WhatsApp (for proactive messages) ──
OWNER_WHATSAPP=

# ── Tally ──
TALLY_UPLOAD_DIR=/tmp/tally_uploads

# ── External Intelligence APIs ──
GOOGLE_PLACES_API_KEY=
APIFY_API_TOKEN=
APIFY_USER_ID=

# ── Auth (empty = disabled, set for production) ──
API_KEY=

# ── Server ──
HOST=0.0.0.0
PORT=8000
DEBUG=false
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MINUTE=120
